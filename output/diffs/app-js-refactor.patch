-function buildDeadLetterPreview(content) {
-    const normalized = String(content || '').trim();
-
-    if (normalized === '') {
-        return 'Kein Textinhalt verfügbar.';
-    }
-
-    if (normalized.length <= 140) {
-        return normalized;
-    }
-
-    return `${normalized.slice(0, 140)} …`;
-}
