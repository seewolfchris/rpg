-        const cleanup = (mode) => {
-            document.removeEventListener('keydown', handleDialogKeydown);
-            document.body.classList.remove('has-overlay-modal');
-            backdrop.remove();
-
-            if (previousFocus instanceof HTMLElement) {
-                previousFocus.focus({ preventScroll: true });
-            }
-
-            resolve(mode);
