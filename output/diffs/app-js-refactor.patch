-function extractQueuedPostContent(entries) {
-    if (!Array.isArray(entries)) {
-        return '';
-    }
-
-    for (const entry of entries) {
-        if (!Array.isArray(entry) || entry.length !== 2) {
-            continue;
-        }
-
-        if (entry[0] === 'content') {
-            return String(entry[1] ?? '');
-        }
-    }
-
-    return '';
-}
