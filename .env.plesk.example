APP_NAME="Chroniken der Asche"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://DEINE-DOMAIN.TLD

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

PRIVACY_NOINDEX_HEADERS=true
PRIVACY_BLOCK_KNOWN_BOTS=true
# PRIVACY_X_ROBOTS_TAG="noindex, nofollow, noarchive, nosnippet, noimageindex, max-snippet:0, max-image-preview:none, max-video-preview:0"

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Plesk: MySQL/MariaDB nutzen (nicht sqlite)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=DEINE_DB
DB_USERNAME=DEIN_DB_USER
DB_PASSWORD=DEIN_DB_PASSWORT

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
# Produktion: asynchrone Retry-Jobs brauchen einen Worker.
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Web Push (VAPID)
VAPID_SUBJECT=mailto:admin@c76.org
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WEBPUSH_AUTOMATIC_PADDING=true
WEBPUSH_TTL=300
WEBPUSH_ICON=/images/icons/icon-192.png
WEBPUSH_BADGE=/images/icons/icon-96.png
WEBPUSH_ENDPOINT_ALLOWED_HOSTS=fcm.googleapis.com,fcmregistrations.googleapis.com,*.push.services.mozilla.com,web.push.apple.com,*.web.push.apple.com

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=DEIN_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=DEIN_SMTP_USER
MAIL_PASSWORD=DEIN_SMTP_PASSWORT
MAIL_FROM_ADDRESS="noreply@DEINE-DOMAIN.TLD"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
