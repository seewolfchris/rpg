APP_NAME="C76-RPG"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=v0.19-beta
# Optional: kurzer Build-Hinweis (z. B. Git-Hash)
# APP_BUILD=
WORLD_DEFAULT_SLUG=chroniken-der-asche

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

PRIVACY_NOINDEX_HEADERS=true
PRIVACY_BLOCK_KNOWN_BOTS=true
PRIVACY_ALLOW_LINK_PREVIEW_BOTS=true
# PRIVACY_X_ROBOTS_TAG="noindex, nofollow, noarchive, nosnippet, noimageindex, max-snippet:0, max-image-preview:none, max-video-preview:0"

# Rechtliche Seiten (Impressum/Datenschutz/Urheberrecht)
LEGAL_RESPONSIBLE_NAME=
LEGAL_RESPONSIBLE_ADDRESS=
LEGAL_CONTACT_EMAIL=
LEGAL_CONTACT_PHONE=
LEGAL_CONTENT_RESPONSIBLE=
LEGAL_CONTROLLER_NAME=
LEGAL_CONTROLLER_ADDRESS=
LEGAL_CONTROLLER_EMAIL=
LEGAL_RIGHTS_CONTACT=
LEGAL_RIGHTS_CONTACT_NOTE=
LEGAL_SOURCE_IMPRINT_URL=https://c76.org/impressum/
LEGAL_SOURCE_PRIVACY_URL=https://c76.org/datenschutz/
LEGAL_SCOPE_NOTE="Dieses Impressum gilt für c76.org und zugehörige Subdomains, inklusive rpg.c76.org."

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chroniken_der_asche
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
