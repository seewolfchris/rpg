APP_NAME="C76-RPG"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=v0.25-beta
# Optional: kurzer Build-Hinweis (z. B. Git-Hash)
APP_BUILD=2637d72
# Optionaler MySQL-Hotpath-Hint fuer posts.latest_by_id:
PERF_POSTS_LATEST_BY_ID_FORCE_INDEX=false
PERF_POSTS_LATEST_BY_ID_FORCE_INDEX_NAME=posts_scene_id_id_idx
# Standard-Welt fuer Routing/Fallbacks (muss als aktive Welt in der DB existieren)
WORLD_DEFAULT_SLUG=deine-standardwelt

# Web Push (VAPID)
# Subject im Format mailto:kontakt@example.org oder https://example.org
VAPID_SUBJECT=mailto:admin@c76.org
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional:
# VAPID_PEM_FILE=
WEBPUSH_DB_TABLE=push_subscriptions
# Optional override (default folgt DB_CONNECTION):
# WEBPUSH_DB_CONNECTION=mysql
WEBPUSH_AUTOMATIC_PADDING=true
WEBPUSH_TTL=300
WEBPUSH_ICON=/images/icons/icon-192.png
WEBPUSH_BADGE=/images/icons/icon-96.png

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

PRIVACY_NOINDEX_HEADERS=true
PRIVACY_BLOCK_KNOWN_BOTS=true
PRIVACY_ALLOW_LINK_PREVIEW_BOTS=true
# PRIVACY_X_ROBOTS_TAG="noindex, nofollow, noarchive, nosnippet, noimageindex, max-snippet:0, max-image-preview:none, max-video-preview:0"

# Feature flags fuer gestuften Rollout (Immersion/Welle 3-4)
FEATURE_WAVE3_EDITOR_PREVIEW=false
FEATURE_WAVE3_DRAFT_AUTOSAVE=false
FEATURE_WAVE4_MENTIONS=false
FEATURE_WAVE4_REACTIONS=false
FEATURE_WAVE4_ACTIVE_CHARACTERS=false

# Rechtliche Seiten (Impressum/Datenschutz/Urheberrecht)
LEGAL_RESPONSIBLE_NAME=
LEGAL_RESPONSIBLE_ADDRESS=
LEGAL_CONTACT_EMAIL=
LEGAL_CONTACT_PHONE=
LEGAL_CONTENT_RESPONSIBLE=
LEGAL_CONTROLLER_NAME=
LEGAL_CONTROLLER_ADDRESS=
LEGAL_CONTROLLER_EMAIL=
LEGAL_RIGHTS_CONTACT=
LEGAL_RIGHTS_CONTACT_NOTE=
LEGAL_SOURCE_IMPRINT_URL=https://c76.org/impressum/
LEGAL_SOURCE_PRIVACY_URL=https://c76.org/datenschutz/
LEGAL_SCOPE_NOTE="Dieses Impressum gilt für c76.org und zugehörige Subdomains, inklusive rpg.c76.org."

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chroniken_der_asche
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
